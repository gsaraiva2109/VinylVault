# ─────────────────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────────────────

# Public URL of this app (used by NextAuth for callbacks)
NEXTAUTH_URL=https://vinyl.yourdomain.com

# Random secret — generate with: openssl rand -base64 32
# NEVER reuse between environments. Rotate if exposed.
NEXTAUTH_SECRET=

# ─────────────────────────────────────────────────────────────
# OIDC provider (Authentik, Keycloak, Auth0, Okta, etc.)
# ─────────────────────────────────────────────────────────────

# Client ID from your OIDC application
OIDC_CLIENT_ID=

# Client secret from your OIDC application
OIDC_CLIENT_SECRET=

# OIDC issuer URL — e.g. https://auth.yourdomain.com/application/o/vinyl-catalog/
OIDC_ISSUER=

# ─────────────────────────────────────────────────────────────
# Backend API
# ─────────────────────────────────────────────────────────────

# Public URL of the vinyl-catalog backend API (exposed to the browser)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ─────────────────────────────────────────────────────────────
# Spotify (Client Credentials — baked into the build)
# Used for auto-enriching scanned records with Spotify album IDs.
# Create an app at https://developer.spotify.com/dashboard
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
