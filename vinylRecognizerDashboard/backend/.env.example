# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vinyl_collection
DB_USER=vinyl_user
DB_PASSWORD=sua_senha_aqui

# ==============================================
# SERVER CONFIGURATION
# ==============================================
PORT=5000
FRONTEND_URL=http://localhost:5173

# ==============================================
# SPOTIFY API CREDENTIALS
# ==============================================
# Obtenha suas credenciais em: https://developer.spotify.com/dashboard
# 1. Crie um app no Spotify Dashboard
# 2. Copie o Client ID e Client Secret
SPOTIFY_CLIENT_ID=seu_client_id_spotify_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_spotify_aqui

# ==============================================
# DISCOGS API CREDENTIALS
# ==============================================
# Obtenha seu token em: https://www.discogs.com/settings/developers
# 1. Clique em "Generate new token"
# 2. Copie o token gerado
DISCOGS_TOKEN=seu_token_discogs_aqui

# ==============================================
# NOTAS
# ==============================================
# - Não commite este arquivo com credenciais reais
# - Use .env.example como referência
# - Mantenha suas credenciais seguras e privadas
