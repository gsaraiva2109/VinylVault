# Domain (no https://)
DOMAIN=vinyl.yourdomain.com

# PostgreSQL — pick a strong password
POSTGRES_PASSWORD=changeme

# Authentik OIDC — application slug must be "vinyl-vault" in Authentik admin
# Provider → Application → slug: vinyl-vault
AUTHENTIK_JWKS_URL=https://auth.yourdomain.com/application/o/vinyl-vault/jwks/
AUTHENTIK_ISSUER=https://auth.yourdomain.com/application/o/vinyl-vault/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Discogs personal access token (https://www.discogs.com/settings/developers)
DISCOGS_TOKEN=

# NextAuth (frontend web service)
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=https://vinyl.yourdomain.com
NEXTAUTH_SECRET=
