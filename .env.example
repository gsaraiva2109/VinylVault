# Domain (no https://)
DOMAIN=vinyl.yourdomain.com

# PostgreSQL — pick a strong password
POSTGRES_PASSWORD=changeme

# Authentik OIDC (from your Authentik provider application)
AUTHENTIK_JWKS_URL=https://auth.yourdomain.com/application/o/vinyl-catalog/jwks/
AUTHENTIK_ISSUER=https://auth.yourdomain.com/application/o/vinyl-catalog/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Discogs personal access token (https://www.discogs.com/settings/developers)
DISCOGS_TOKEN=

# NextAuth (frontend web service)
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=https://vinyl.yourdomain.com
NEXTAUTH_SECRET=
