# Domain (no https://)
DOMAIN=vinyl.yourdomain.com

# PostgreSQL — pick a strong password
POSTGRES_PASSWORD=changeme

# OIDC Authentication — works with Authentik, Keycloak, Auth0, Okta, etc.
# OIDC_JWKS_URL is optional — derived from OIDC_ISSUER/.well-known/openid-configuration if not set
OIDC_JWKS_URL=https://auth.yourdomain.com/application/o/vinyl-vault/jwks/
OIDC_ISSUER=https://auth.yourdomain.com/application/o/vinyl-vault/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Discogs personal access token (https://www.discogs.com/settings/developers)
DISCOGS_TOKEN=

# Allowed CORS origins for the API (comma-separated).
# Must include tauri://localhost for the desktop app to connect.
ALLOWED_ORIGINS=https://vinyl.yourdomain.com,tauri://localhost

# NextAuth (frontend web service)
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=https://vinyl.yourdomain.com
NEXTAUTH_SECRET=

# AES-256-GCM encryption key for user API keys (64 hex chars = 32 bytes)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=
