{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vinyl Vault",
  "version": "1.3.5",
  "identifier": "com.gsaraiva2109.vinyl-vault",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../web && pnpm dev --turbopack",
    "beforeBuildCommand": "bash scripts/build-frontend.sh"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vinyl Vault",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:3000; script-src 'self' 'unsafe-inline' http://localhost:3000; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob:; connect-src 'self' http://localhost:3000 https://api-vinyl.gsaraiva.com.br https://auth.gsaraiva.com.br https://api.spotify.com https://api.discogs.com https://generativelanguage.googleapis.com https://api.openai.com ipc: http://ipc.localhost ws://localhost:3000"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {}
    },
    "macOS": {
      "entitlements": "Entitlements-macOS.plist",
      "infoPlist": "Info.plist"
    },
    "publisher": "gsaraiva2109",
    "category": "Music"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "vinylapp"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2NEFDNkYwRTQwRDhEQzIKUldUQ2pRM2s4TVpLVnJMUFpmNENTTnFzNFFTK3F2dmlEUEFLdytQTUVoNXgyZU5JcHMxV3FLTFYK",
      "endpoints": [
        "https://github.com/gsaraiva2109/vinylvault/releases/latest/download/latest.json"
      ]
    }
  }
}
