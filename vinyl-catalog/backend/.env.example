PORT=3001
DB_PATH=./data/vinyl-catalog.db

# Auth (Phase 6) — set AUTH_ENABLED=false during local dev
AUTH_ENABLED=false
AUTHENTIK_JWKS_URL=https://auth.yourdomain.com/application/o/vinyl-vault/jwks/
AUTHENTIK_ISSUER=https://auth.yourdomain.com/application/o/vinyl-vault/

# Discogs API token (server-side only — never in frontend client)
DISCOGS_TOKEN=your_discogs_personal_access_token
