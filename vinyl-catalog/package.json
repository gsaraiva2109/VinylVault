{
  "name": "vinyl-vault",
  "version": "1.0.19",
  "description": "VinylVault — Tauri desktop app",
  "author": "gsaraiva2109",
  "repository": "https://github.com/gsaraiva2109/vinylvault",
  "scripts": {
    "dev": "WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev",
    "build": "tauri build",
    "build:frontend": "bash scripts/build-frontend.sh",
    "build:linux": "pnpm build:frontend && tauri build --target x86_64-unknown-linux-gnu",
    "build:mac": "pnpm build:frontend && tauri build --target aarch64-apple-darwin",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.97.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
