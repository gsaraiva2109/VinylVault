{
  "name": "vinyl-vault",
  "version": "1.0.8",
  "description": "VinylVault — Tauri desktop app",
  "author": "gsaraiva2109",
  "repository": "https://github.com/gsaraiva2109/vinylvault",
  "scripts": {
    "dev": "WEBKIT_DISABLE_DMABUF_RENDERER=1 tauri dev",
    "vite": "vite",
    "build": "vite build",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "build:mac": "tauri build --target aarch64-apple-darwin",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.8",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
