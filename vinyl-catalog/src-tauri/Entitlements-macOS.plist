<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        No keychain-access-groups entitlement is needed here.
        That entitlement is for cross-app keychain sharing only; a single app
        can read/write its own Keychain items under Hardened Runtime without it.
        Using $(AppIdentifierPrefix) with ad-hoc signing leaves the macro
        unexpanded, which causes Security.framework to apply an invalid group
        filter on reads even though writes succeed.
    -->
</dict>
</plist>
